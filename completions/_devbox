#compdef devbox

# Zsh completion for devbox
# Install: copy to a directory in $fpath (e.g. /usr/local/share/zsh/site-functions/)

_devbox_containers() {
    # Shared infra (`devbox_traefik`, `devbox_dns`) uses underscore separator
    # and is naturally excluded by the dash-prefix filter above. The grep
    # below filters legacy dash-separator names that may still be running
    # before `devbox update` migrates them away (see ADR 0007).
    local -a containers
    containers=(${(f)"$(docker ps --filter 'name=^devbox-' \
        --format '{{.Names}}' 2>/dev/null \
        | grep -vE '^devbox-(traefik|dns)$' | sed 's/^devbox-//')"})
    _describe 'running devbox containers' containers
}

_devbox() {
    local state
    _arguments \
        '1: :->cmd' \
        '*: :->args'

    case $state in
        cmd)
            local -a commands
            commands=(
                'help:Show help message'
                'ls:List running containers'
                'stop:Stop container (--clean removes volumes)'
                'remove:Remove project data (volumes)'
                'port:Expose port via Traefik'
                'ports:List active port routes'
                'connect:Forward inner containers to another devbox'
                'connections:List cross-devbox TCP forwards'
                'build:Build/rebuild the devbox image'
                'update:Update devbox (pull repo + rebuild image)'
                'uninstall:Remove everything (containers, volumes, image)'
                'prune:Remove Docker build cache and dangling images'
                'claude-token:Generate/regenerate Claude Code token'
                'allow:List or add allowed firewall domain'
                'deny:Remove allowed domain (interactive)'
                'blocked:Show blocked DNS queries, allow interactively'
                'allow-for:Open a time-bounded Allow-for window (default 15 min)'
                'agent-browser:Control Host agent Chrome (start/stop/status/allow-for)'
                'cursor:Open Cursor attached to running devbox'
                'code:Open VS Code attached to running devbox'
                'clip:Grab clipboard image for container use'
                'ssh-config:Manage devbox SSH config'
                'sync-skills:Sync host skills to all running containers'
                'dns-install:Configure host resolver for *.test (per-OS)'
                'dns-status:Show DNS mode, resolver state, verification'
                'dns-uninstall:Remove host resolver config + dns.conf'
            )
            _describe 'devbox commands' commands
            ;;
        args)
            case $words[2] in
                stop)
                    if (( CURRENT == 3 )); then
                        _devbox_containers
                    elif (( CURRENT == 4 )); then
                        local -a flags
                        flags=('--clean:Stop and remove project volumes')
                        _describe 'flags' flags
                    fi
                    ;;
                cursor|code|remove)
                    _devbox_containers
                    ;;
                allow-for)
                    # Positionals can be in any order: minutes (numeric) or
                    # project name. --stop is a flag.
                    if (( CURRENT == 3 )) || (( CURRENT == 4 )); then
                        _devbox_containers
                        local -a flags
                        flags=('--stop:Close the active window immediately')
                        _describe 'flags' flags
                    fi
                    ;;
                connect)
                    if (( CURRENT == 3 )); then
                        _devbox_containers
                    elif (( CURRENT == 5 )); then
                        local -a flags
                        flags=('--from:Source devbox container')
                        _describe 'flags' flags
                    fi
                    ;;
                build)
                    local -a flags
                    flags=(
                        '--clean:Full reset (volumes + cache) + rebuild'
                        '--no-cache:Full rebuild without cache'
                        '--progress=plain:Show full build log'
                    )
                    _describe 'build flags' flags
                    ;;
                ssh-config)
                    local -a actions
                    actions=(
                        'add:Add SSH host to devbox config'
                        'edit:Edit devbox SSH config'
                    )
                    _describe 'ssh-config actions' actions
                    ;;
                dns-install)
                    local -a flags
                    flags=(
                        '--auto:Try local, fall back to external on failure (default)'
                        '--local:Force local mode; fail loud if setup fails'
                        '--external:Skip resolver setup; persist external sslip.io mode'
                        '--enable-https:Install mkcert CA + flip https.conf active=true'
                        '--disable-https:Flip https.conf active=false (CA stays installed)'
                        '--purge-ca:Remove mkcert CA from trust stores + delete https.conf'
                    )
                    _describe 'dns-install flags' flags
                    ;;
                uninstall)
                    local -a flags
                    flags=(
                        '--purge-ca:Also strip mkcert CA from native + Windows trust stores'
                    )
                    _describe 'uninstall flags' flags
                    ;;
                ports)
                    local -a flags
                    flags=(
                        '--all:Include stopped containers and skip listening filter'
                        '--external:Show sslip.io URL alongside the active URL'
                    )
                    _describe 'ports flags' flags
                    ;;
                agent-browser)
                    # Layout: devbox agent-browser <sub> [args]
                    #   CURRENT==3 → subcommand
                    #   CURRENT==4 → container (start/stop/status) OR
                    #                minutes/--stop (allow-for)
                    #   CURRENT==5 → container (allow-for only)
                    if (( CURRENT == 3 )); then
                        local -a subs
                        subs=(
                            'start:Launch Host agent Chrome bound to container'
                            'stop:Stop session and clean up resources'
                            'status:Show session state (Chrome/proxy/watchdog PIDs)'
                            'allow-for:Open time-bounded network window (default mode)'
                            'help:Show agent-browser help'
                        )
                        _describe 'agent-browser subcommands' subs
                    elif (( CURRENT == 4 )); then
                        case $words[3] in
                            start|stop|status)
                                _devbox_containers
                                ;;
                            allow-for)
                                # First positional is minutes (numeric)
                                # or --stop. Container resolution happens
                                # at CURRENT==5 below.
                                local -a flags
                                flags=('--stop:Close the active window immediately')
                                _describe 'allow-for flags' flags
                                _devbox_containers
                                ;;
                        esac
                    elif (( CURRENT == 5 )); then
                        if [ "$words[3]" = "allow-for" ]; then
                            _devbox_containers
                        fi
                    fi
                    ;;
            esac
            ;;
    esac
}

_devbox "$@"
